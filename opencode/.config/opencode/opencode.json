{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mempalace": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "mempalace.mcp_server"
      ]
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      }
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      }
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "{env:STITCH_API_KEY}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "godot": {
      "command": [
        "bunx",
        "-y",
        "godot-mcp-server"
      ],
      "type": "local"
    },
    "drizzle": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "github:defrex/drizzle-mcp"
      ],
    },
    "linear": {
      "command": [
        "bunx",
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ],
      "type": "local"
    },
    "next-devtools": {
      "command": [
        "bunx",
        "-y",
        "next-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "nuxt": {
      "type": "remote",
      "url": "https://nuxt.com/mcp"
    },
    "nuxt-ui": {
      "type": "local",
      "command": [
        "bunx",
        "mcp-remote",
        "https://ui.nuxt.com/mcp"
      ]
    },
    "tauri": {
      "type": "local",
      "command": [
        "bunx",
        "@hypothesi/tauri-mcp-server"
      ],
    },
    "svelte": {
      "type": "remote",
      "url": "https://mcp.svelte.dev/mcp"
    }
  },
  "model": "zai-coding-plan/glm-5.1",
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
}
